{
  "name": "node-ts-starter",
  "version": "0.1.0",
  "type": "module",
  "description": "Minimal Node.js + TypeScript starter kit",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
